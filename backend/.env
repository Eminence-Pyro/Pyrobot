# ── PYROBOT ENVIRONMENT VARIABLES ────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://pyrobot_user:your-password@localhost:5432/pyrobot

# ── AUTHENTICATION ────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=replace-with-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI PROVIDERS ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...        # Optional — for Claude provider
GOOGLE_API_KEY=...                  # Optional — for Gemini provider

# Default model used when none is specified
DEFAULT_AI_MODEL=gpt-4o

# ── FRONTEND (Next.js) ────────────────────────────────────────
# These are exposed to the browser — never put secrets here
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── BACKEND ───────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── STORAGE ───────────────────────────────────────────────────
# dev: local | prod: s3
STORAGE_BACKEND=local
# AWS_S3_BUCKET=your-bucket-name       # Uncomment for production S3
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
