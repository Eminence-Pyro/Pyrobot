# ── PYROBOT ENVIRONMENT VARIABLES ────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── DATABASE ──────────────────────────────────────────────────
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://pyrobot_user:your-password@localhost:5432/pyrobot


# ── AUTHENTICATION ────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=replace-with-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI PROVIDERS ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...        # Optional — for Claude provider
GOOGLE_API_KEY=...                  # Get free at aistudio.google.com — for Gemini provider
GROQ_API_KEY=gsk_...                # Get free at console.groq.com — for Groq provider

# Default model used when none is specified (production-intended value)
DEFAULT_AI_MODEL=gpt-5.5

# ── DEV TESTING OVERRIDE ───────────────────────────────────────
# No OpenAI/Anthropic credits yet? In your REAL .env (not this file),
# uncomment ONE line below to test the chat pipeline for free:
# DEFAULT_AI_MODEL=llama-3.3-70b-versatile   # Groq — fastest, most generous free tier
# DEFAULT_AI_MODEL=gemini-2.5-flash          # Gemini — strong quality, free tier
# DEFAULT_AI_MODEL=gpt-5.5                    # OpenAI — most capable, paid

# ── FRONTEND (Next.js) ────────────────────────────────────────
# These are exposed to the browser — never put secrets here
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── BACKEND ───────────────────────────────────────────────────
# BACKEND_CORS_ORIGINS=http://localhost:3000 (incorrect: single string)

# Correct: Wrapped in brackets and double quotes
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# ── STORAGE ───────────────────────────────────────────────────
# dev: local | prod: s3
STORAGE_BACKEND=local
# AWS_S3_BUCKET=your-bucket-name       # Uncomment for production S3
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

POSTGRES_USER=pyrobot
POSTGRES_PASSWORD=pyrobot_dev_password
POSTGRES_DB=pyrobot